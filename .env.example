# Turso (database). Locally you can use a plain file instead of Turso:
#   TURSO_DATABASE_URL=file:local.db
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=

# Clerk (auth) — create an app at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# OpenRouter (AI) — https://openrouter.ai/keys
# This single key powers the builder chat AND window.ai inside generated apps.
OPENROUTER_API_KEY=sk-or-...
